[global]
ioengine=filecreate
thread=1
group_reporting=1

create_on_open=1
create_serialize=0
create_fsync=0

openfiles=1
filesize=4k

numjobs=2
nrfiles=8000

directory=/mnt/fuse/fuse-create/case02-run
filename_format=file.$jobnum.$filenum
unique_filename=0

cpus_allowed=0,1
cpus_allowed_policy=split

[create]
